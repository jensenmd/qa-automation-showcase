{
  "info": {
    "name": "OpenBreweryDB API — QA Showcase",
    "description": "Postman collection demonstrating API validation techniques: request chaining, environment variables, JavaScript test scripts, schema validation, and business rule assertions.",
    "_postman_id": "qa-showcase-brewery-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://api.openbrewerydb.org/v1", "type": "string" },
    { "key": "brewery_id", "value": "", "type": "string" },
    { "key": "per_page", "value": "10", "type": "string" }
  ],
  "item": [
    {
      "name": "1. List Breweries — Status & Schema",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/breweries?per_page={{per_page}}",
          "host": ["{{base_url}}"],
          "path": ["breweries"],
          "query": [{ "key": "per_page", "value": "{{per_page}}" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// ── Status Code ──────────────────────────────────────",
              "pm.test('Status code is 200', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// ── Content-Type ─────────────────────────────────────",
              "pm.test('Content-Type is application/json', () => {",
              "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
              "});",
              "",
              "// ── Response is array ────────────────────────────────",
              "pm.test('Response body is an array', () => {",
              "    const data = pm.response.json();",
              "    pm.expect(data).to.be.an('array');",
              "    pm.expect(data.length).to.be.greaterThan(0);",
              "});",
              "",
              "// ── Required fields on every object ──────────────────",
              "pm.test('Each brewery has required fields', () => {",
              "    const data = pm.response.json();",
              "    const required = ['id', 'name', 'brewery_type', 'city', 'state', 'country'];",
              "    data.forEach(brewery => {",
              "        required.forEach(field => {",
              "            pm.expect(brewery).to.have.property(field);",
              "        });",
              "    });",
              "});",
              "",
              "// ── Brewery type enum validation ──────────────────────",
              "pm.test('brewery_type values are valid enum', () => {",
              "    const validTypes = ['micro','nano','regional','brewpub','large',",
              "                        'planning','bar','contract','proprietor','closed'];",
              "    const data = pm.response.json();",
              "    data.forEach(brewery => {",
              "        pm.expect(validTypes).to.include(brewery.brewery_type,",
              "            `Invalid type: ${brewery.brewery_type} for ${brewery.name}`);",
              "    });",
              "});",
              "",
              "// ── Chain: save first ID for next request ────────────",
              "const data = pm.response.json();",
              "if (data.length > 0) {",
              "    pm.collectionVariables.set('brewery_id', data[0].id);",
              "    console.log('Saved brewery_id for chaining:', data[0].id);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2. Get Single Brewery (Chained ID)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/breweries/{{brewery_id}}",
          "host": ["{{base_url}}"],
          "path": ["breweries", "{{brewery_id}}"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is a single object (not array)', () => {",
              "    const data = pm.response.json();",
              "    pm.expect(data).to.be.an('object');",
              "    pm.expect(data).to.not.be.an('array');",
              "});",
              "",
              "pm.test('Returned brewery ID matches requested ID', () => {",
              "    const data = pm.response.json();",
              "    const requestedId = pm.collectionVariables.get('brewery_id');",
              "    pm.expect(data.id).to.eql(requestedId);",
              "});",
              "",
              "pm.test('Website URL is valid format if present', () => {",
              "    const data = pm.response.json();",
              "    if (data.website_url) {",
              "        pm.expect(data.website_url).to.match(/^https?:\\/\\//);",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "3. Filter by Type — Business Rule Validation",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/breweries?by_type=micro&per_page=20",
          "host": ["{{base_url}}"],
          "path": ["breweries"],
          "query": [
            { "key": "by_type", "value": "micro" },
            { "key": "per_page", "value": "20" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('All results have brewery_type = micro', () => {",
              "    const data = pm.response.json();",
              "    pm.expect(data.length).to.be.greaterThan(0);",
              "    data.forEach(b => {",
              "        pm.expect(b.brewery_type).to.eql('micro',",
              "            `Expected micro, got ${b.brewery_type} for ${b.name}`);",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "4. Filter by State — Colorado",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/breweries?by_state=colorado&per_page=10",
          "host": ["{{base_url}}"],
          "path": ["breweries"],
          "query": [
            { "key": "by_state", "value": "colorado" },
            { "key": "per_page", "value": "10" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Results contain Colorado breweries', () => {",
              "    const data = pm.response.json();",
              "    pm.expect(data.length).to.be.greaterThan(0);",
              "    data.forEach(b => {",
              "        pm.expect(b.state.toLowerCase()).to.eql('colorado');",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "5. Search Endpoint — Relevance Check",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/breweries/search?query=sierra&per_page=5",
          "host": ["{{base_url}}"],
          "path": ["breweries", "search"],
          "query": [
            { "key": "query", "value": "sierra" },
            { "key": "per_page", "value": "5" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Search returns results', () => {",
              "    const data = pm.response.json();",
              "    pm.expect(data).to.be.an('array');",
              "    pm.expect(data.length).to.be.greaterThan(0);",
              "});",
              "",
              "pm.test('Response time under 3 seconds', () => {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "6. Invalid ID — 404 Handling",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/breweries/this-id-does-not-exist-xyz",
          "host": ["{{base_url}}"],
          "path": ["breweries", "this-id-does-not-exist-xyz"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Invalid ID returns 404', () => {",
              "    pm.response.to.have.status(404);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "7. Random Brewery Endpoint",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/breweries/random",
          "host": ["{{base_url}}"],
          "path": ["breweries", "random"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', () => {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Returns array with one brewery', () => {",
              "    const data = pm.response.json();",
              "    pm.expect(data).to.be.an('array');",
              "    pm.expect(data.length).to.eql(1);",
              "});",
              "",
              "pm.test('Random brewery has required fields', () => {",
              "    const brewery = pm.response.json()[0];",
              "    ['id','name','brewery_type'].forEach(f => {",
              "        pm.expect(brewery).to.have.property(f);",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
